#!/bin/bash

# `.functions` provides helper functions for shell.
#
# This file is used as a part of `.shell_env`

git-dowloadfolder() {
  # Downloads folder from git repository.
  url="$1"
  svn checkout ${url/tree\/master/trunk}
}

transfer() {
  # Transfers text file as sharable link.
  # See https://transfer.sh/
  if [ $# -eq 0 ]; then
    echo "No arguments specified. Usage:\necho transfer /tmp/test.md\ncat /tmp/test.md | transfer test.md"
    return 1
  fi
  tmpfile=$(mktemp -t transferXXX)
  if tty -s; then
    basefile=$(basename "$1" | sed -e 's/[^a-zA-Z0-9._-]/-/g')
    curl --progress-bar --upload-file "$1" "https://transfer.sh/$basefile" >>$tmpfile
  else curl --progress-bar --upload-file "-" "https://transfer.sh/$1" >>$tmpfile; fi
  cat $tmpfile
  rm -f $tmpfile
}

mk() {
  # Create a new directory and enter it
  mkdir -p "$@" && cd "$@"
}

cdf() {
  # cd into whatever is the forefront Finder window.
  local finder_path=$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')
  echo "$finder_path"
  cd "$finder_path"
}

# find-in-file - usage: fif <SEARCH_TERM>
fif() {
  if [ ! "$#" -gt 0 ]; then
    echo "Need a string to search for!"
    return 1
  fi
  rg --files-with-matches --no-messages "$1" | fzf $FZF_PREVIEW_WINDOW --preview "rg --ignore-case --pretty --context 10 '$1' {}"
}

# like normal z when used with arguments but displays an fzf prompt when used without.
#unalias z 2> /dev/null
f() {
  [ $# -gt 0 ] && _z "$*" && return
  cd "$(z -l 2>&1 | fzf --height 40% --nth 2.. --reverse --inline-info +s --tac --query "${*##-* }" | sed 's/^[0-9,.]* *//')"
}

fbr() {
  local branches branch
  branches=$(git --no-pager branch -vv) &&
    branch=$(echo "$branches" | fzf +m) &&
    git checkout $(echo "$branch" | awk '{print $1}' | sed "s/.* //")
}

# fco - FZF fuzzy checkout git branch/tag
fco() {
  local tags branches target
  branches=$(
    git --no-pager branch --all \
      --format="%(if)%(HEAD)%(then)%(else)%(if:equals=HEAD)%(refname:strip=3)%(then)%(else)%1B[0;34;1mbranch%09%1B[m%(refname:short)%(end)%(end)" |
      sed '/^$/d'
  ) || return
  tags=$(
    git --no-pager tag | awk '{print "\x1b[35;1mtag\x1b[m\t" $1}'
  ) || return
  target=$(
    (
      echo "$branches"
      echo "$tags"
    ) |
      fzf --no-hscroll --no-multi -n 2 \
        --ansi
  ) || return
  git checkout $(awk '{print $2}' <<<"$target")
}

bindkey -s "^ p" "fbr^J"

# git pull (ctrl-g+p)
function gitPull() {
  git pull
}

bindkey -s "^ g" "gitPull^J"

killport() {
  kill $(lsof -ti:$1)
}
#Yazi
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

function ya_zed() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXX")"
  yazi "$@" --chooser-file="$tmp"

  local opened_file=$(cat -- "$tmp" | head -n 1)
  zed-preview -- "$opened_file"

  rm -f -- "$tmp"
  exit
}

git_branch_and_status() {
  local branch dirty
  # Check if in a git repository
  if git rev-parse --is-inside-work-tree &> /dev/null; then
    # Get branch name
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)
    # Check for dirty state
    dirty=$(git diff --quiet --ignore-submodules HEAD &>/dev/null || echo " +")
    echo "(${branch}${dirty})"
  fi
}

# Worktrees
# Usage:
# cd ~/repos/kibana/kibana-main
# wt jon/fix-esql-label  → creates ../jon/fix-esql-label

wt () {
  local name="$1"
  local base="${2:-upstream/main}"

  git fetch upstream || return 1

  # If upstream/$name exists, track it rather than branching off $base
  if git show-ref --verify --quiet "refs/remotes/upstream/$name"; then
    if ! git show-ref --verify --quiet "refs/heads/$name"; then
      git branch --track "$name" "upstream/$name" || return 1
    fi
    git worktree add "../$name" "$name"
  else
    git worktree add "../$name" -b "$name" "$base"
  fi
}

# Worktree for a tag
# Usage:
# cd ~/repos/kibana/kibana-main
# wtv v9.3.1  → fetches tag, creates local branch, opens worktree at ../v9.3.1
wtv () {
  local tag="$1"
  local dir="${2:-../$tag}"

  if [ -z "$tag" ]; then
    echo "usage: wtv <tag> [dir]"
    return 1
  fi

  git fetch upstream "refs/tags/$tag:refs/tags/$tag" || return 1

  if ! git show-ref --verify --quiet "refs/heads/$tag"; then
    git branch "$tag" "refs/tags/$tag" || return 1
  fi

  git worktree add "$dir" "$tag"
}

# Worktrees for existing branches
# Usage:
# cd ~/repos/kibana/kibana-main
# wtexisting jon/fix-alert-bug  → creates ../fix-alert-bug
wtexisting () {
  local branch="$1"
  local dir="${2:-../${branch##*/}}"

  if [ -z "$branch" ]; then
    echo "usage: wtexisting <branch> [dir]"
    return 1
  fi

  git show-ref --verify --quiet "refs/heads/$branch" || {
    echo "local branch does not exist: $branch"
    return 1
  }

  git worktree add "$dir" "$branch"
}

# Worktrees for fetch a remote branch, create a local tracking branch, and open it as a worktree
# Usage:
# cd ~/repos/kibana/kibana-main
# wttrack origin jon/fix-alert-bug          → creates ../fix-alert-bug
# wttrack jane my-branch jane/my-branch ../my-branch
wttrack () {
  local remote="$1"
  local branch="$2"
  local local_branch="${3:-$branch}"
  local dir="${4:-../${local_branch##*/}}"

  if [ -z "$remote" ] || [ -z "$branch" ]; then
    echo "usage: wttrack <remote> <remote-branch> [local-branch] [dir]"
    return 1
  fi

  git fetch "$remote" || return 1

  if ! git show-ref --verify --quiet "refs/heads/$local_branch"; then
    git branch --track "$local_branch" "$remote/$branch" || return 1
  fi

  git worktree add "$dir" "$local_branch"
}

# Worktrees for fetch a PR, create a local tracking branch, and open it as a worktree
# Usage:
# cd ~/repos/kibana/kibana-main
# wtpr 12345                      → creates ../pr-12345
# wtpr 12345 pr/12345-jane ../pr-12345-jane

wtpr () {
  local pr="$1"
  local local_branch="${2:-pr/$pr}"
  local dir="${3:-../pr-$pr}"

  if [ -z "$pr" ]; then
    echo "usage: wtpr <pr-number> [local-branch] [dir]"
    return 1
  fi

  git fetch upstream "pull/$pr/head:$local_branch" || return 1
  git worktree add "$dir" "$local_branch"
}

# Cleanup worktree and optionally delete branch
# Usage:
# Normal cleanup
# wtrm fix-alert-bug
#
# Force remove (if dirty worktree)
# wtrm fix-alert-bug --force
#
# Remove + delete branch
# wtrm fix-alert-bug --force --delete-branch

wtrm () {
  local wt_path="$1"
  local force="$2"   # optional: --force
  local delete_branch="$3"  # optional: --delete-branch

  if [ -z "$wt_path" ]; then
    echo "usage: wtrm <name> [--force] [--delete-branch]"
    return 1
  fi

  # Normalize path (remove trailing slash)
  wt_path="${wt_path%/}"

  # Prepend ../ if no path separators given
  if [[ "$wt_path" != */* ]]; then
    wt_path="../${wt_path}"
  fi

  # Try to detect branch from worktree
  local branch=""
  if [ -d "$wt_path/.git" ] || [ -f "$wt_path/.git" ]; then
    branch=$(git -C "$wt_path" branch --show-current 2>/dev/null)
  fi

  # Attempt proper removal first
  if git worktree list | grep -q "$wt_path"; then
    echo "Removing worktree via git: $wt_path"
    if [ "$force" = "--force" ]; then
      git worktree remove --force "$wt_path"
    else
      git worktree remove "$wt_path" || {
        echo "Failed (maybe uncommitted changes). Retry with --force"
        return 1
      }
    fi
  else
    echo "Worktree not registered, removing manually: $wt_path"
    rm -rf "$wt_path"
  fi

  # Always prune to clean stale metadata
  git worktree prune

  # Optionally delete branch
  if [ "$delete_branch" = "--delete-branch" ] && [ -n "$branch" ]; then
    echo "Deleting branch: $branch"
    git branch -D "$branch"
  fi

  echo "Done."
}
